# =============================================================
# CoreOps — Configuração
# =============================================================
#
# O CoreOps auto-detecta o LLM disponível no ambiente.
# Quando rodando dentro de Claude Code CLI ou Gemini CLI,
# NÃO é necessário configurar API key — a sessão já está ativa.
#
# Ordem de preferência automática:
#   1. claude CLI  (Claude Code — sessão já autenticada)
#   2. gemini CLI  (Gemini CLI  — sessão já autenticada)
#   3. Anthropic API direta (ANTHROPIC_API_KEY abaixo)

# -------------------------------------------------------
# LLM
# -------------------------------------------------------

# Forçar um adapter específico (opcional — auto-detecta por padrão)
# COREOPS_ADAPTER=claude-cli    # usa `claude --print`
# COREOPS_ADAPTER=gemini-cli    # usa `gemini`
# COREOPS_ADAPTER=anthropic-api # usa API direta (requer KEY abaixo)

# Anthropic API Key — necessário APENAS se não estiver em Claude Code / Gemini CLI
# ANTHROPIC_API_KEY=sk-ant-...

# Modelo padrão (opcional — cada CLI usa seu default)
# COREOPS_MODEL=claude-sonnet-4-6

# -------------------------------------------------------
# Pipeline
# -------------------------------------------------------

# Nível de log: debug | info | warn | error
COREOPS_LOG_LEVEL=info

# Timeout de execução de agente em ms (padrão: 2 minutos)
COREOPS_AGENT_TIMEOUT=120000

# Máximo de retries do loop de microtask (padrão: 3)
COREOPS_MAX_RETRIES=3

# -------------------------------------------------------
# Agentes avançados (Phase 8 — desativados por padrão)
# -------------------------------------------------------

# SecurityAgent: scan OWASP Top 10 em cada microtask
# Bloqueia execução se encontrar vulnerabilidade crítica
# COREOPS_SECURITY=true

# RefactorAgent: refactoring automático após validação
# COREOPS_REFACTOR=true

# DocumentationAgent: adiciona JSDoc/TSDoc automaticamente
# COREOPS_DOCS=true

# -------------------------------------------------------
# Otimizações (Phase 9)
# -------------------------------------------------------

# Cache SQLite de respostas do LLM em ~/.coreops/llm-cache.db
# TTL padrão: 7 dias. Desativar para sempre chamar o LLM.
# COREOPS_LLM_CACHE=false   # descomente para desativar

# -------------------------------------------------------
# Servidor REST (Phase 10)
# -------------------------------------------------------

# Porta do servidor HTTP (`coreops serve`)
# COREOPS_PORT=3000

# Host do servidor (padrão: 0.0.0.0 — todas as interfaces)
# COREOPS_HOST=127.0.0.1
